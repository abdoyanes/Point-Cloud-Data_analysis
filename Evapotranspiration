        "df_seas_top = df_seasonal[df_seasonal['LULC_Name'].isin(top_classes)]\n",
        "\n",
        "season_order  = ['Dry (Nov–Apr)', 'Early Wet (May–Jun)', 'Peak Wet (Jul–Oct)']\n",
