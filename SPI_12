        "# ============================================================\n",
        "# SPI-12 DROUGHT ANALYSIS FIGURES — Google Colab\n",
        "# Three Hydro-Climatic Phases (1952–2022)\n",
        "# Ed Dueim & Kosti Stations, White Nile State, Sudan\n",
        "# ============================================================\n",
        "# CELLS: paste each ## CELL block into a separate Colab cell\n",
        "# ============================================================\n",
        "\n",
        "## CELL 1 — Core Imports and Data Processing\n",
        "from google.colab import files\n",
        "import pandas as pd, numpy as np\n",
        "from scipy.stats import gamma, norm\n",
        "import warnings; warnings.filterwarnings('ignore')\n",
        "print(\"✔ Core Imports ready\")\n",
        "\n",
        "## CELL 2 — Upload data\n",
        "print(\"Upload: Ed Dueim_Station.csv  and  Kosti_Station.csv\")\n",
        "uploaded = files.upload()\n",
        "\n",
        "## CELL 3 — Compute SPI-12 (calendar-month gamma fit — McKee et al. 1993)\n",
        "def compute_spi(fname, scale=12):\n",
        "    df = pd.read_csv(fname)\n",
        "    df.columns = [c.lower() for c in df.columns]\n",
        "    df.rename(columns={'date':'year','rainfall':'rainfall_mm'}, inplace=True)\n",
        "    df = df.sort_values(['year','month']).reset_index(drop=True)\n",
        "    df['roll'] = df['rainfall_mm'].rolling(scale, min_periods=scale).sum()\n",
        "    spi_vals = np.full(len(df), np.nan)\n",
        "    for m in range(1, 13):\n",
        "        idx = df[df['month']==m].index\n",
        "        x   = df.loc[idx,'roll'].dropna().values\n",
        "        wet = x[x>0]; q0 = (len(x)-len(wet)) / len(x)\n",
        "        if len(wet) < 4: continue\n",
        "        try:\n",
        "            a, loc, sc = gamma.fit(wet, floc=0)\n",
        "            for i in idx:\n",
        "                v = df.loc[i,'roll']\n",
        "                if np.isnan(v): continue\n",
        "                cdf = q0 if v<=0 else q0 + (1-q0)*gamma.cdf(v, a, loc, sc)\n",
        "                spi_vals[i] = norm.ppf(np.clip(cdf, 1e-6, 1-1e-6))\n",
        "        except: pass\n",
        "    df['spi12'] = spi_vals\n",
        "    return df\n",
        "\n",
        "dd = compute_spi('/content/Ed Dueim_Station.csv')\n",
        "dk = compute_spi('/content/Kosti_Station.csv')\n",
        "\n",
        "def annual_spi(df):\n",
        "    return df.dropna(subset=['spi12']).groupby('year')['spi12'].mean()\n",
        "\n",
        "ann_d = annual_spi(dd)\n",
        "ann_k = annual_spi(dk)\n",
        "\n",
        "def spi_matrix(df):\n",
        "    d2 = df.dropna(subset=['spi12'])\n",
        "    yrs = sorted(d2['year'].unique())\n",
        "    mat = np.full((12, len(yrs)), np.nan)\n",
        "    for yi, yr in enumerate(yrs):\n",
        "        for m in range(1, 13):\n",
        "            v = d2[(d2['year']==yr)&(d2['month']==m)]['spi12'].values\n",
        "            if len(v): mat[m-1, yi] = v[0]\n",
        "    return mat, np.array(yrs)\n",
        "\n",
        "mat_d, yrs_d = spi_matrix(dd)\n",
        "mat_k, yrs_k = spi_matrix(dk)\n",
        "\n",
        "# Phase definitions\n",
        "PHASES = [\n",
        "    (1952, 1969, 'Ph.I\\n1952-69',   '#5B8DB8', 'Pre-drought'),\n",
        "    (1970, 1989, 'Ph.II\\n1970-89',  '#C0392B', 'Pan-Sahelian drought'),\n",
        "    (1990, 2004, 'Ph.III\\n1990-04', '#27AE60', 'Partial recovery'),\n",
        "    (2005, 2022, 'Ph.IV\\n2005-22',  '#E67E22', 'High-freq. oscillation'),\n",
        "]\n",
        "print(\"Phase mean SPI-12:\")\n",
        "for y1,y2,lbl,col,desc in PHASES:\n",
        "    md = ann_d[(ann_d.index>=y1)&(ann_d.index<=y2)].mean()\n",
        "    mk = ann_k[(ann_k.index>=y1)&(ann.index<=y2)].mean()\n",
        "    print(f\"  {desc:<28} Ed Dueim: {md:+.3f}  Kosti: {mk:+.3f}\")\n",
        "print(\"✔ SPI computed\")"
