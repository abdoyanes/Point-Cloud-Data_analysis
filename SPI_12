        "## CELL 4 — Plotting Setup\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.gridspec as gridspec\n",
        "import matplotlib.patches as mpatches\n",
        "import matplotlib.ticker as mticker\n",
        "from matplotlib.colors import LinearSegmentedColormap, BoundaryNorm\n",
        "from scipy.ndimage import uniform_filter1d\n",
        "\n",
        "# Define plotting constants and styles\n",
        "CMAP_C = ['#7B0000','#C0392B','#E74C3C','#F39C12',\n",
        "          '#F8F9FA','#85C1E9','#2E86C1','#1B4F72','#0B2D47']\n",
        "cmap  = LinearSegmentedColormap.from_list('spi', CMAP_C, N=512)\n",
        "bnorm = BoundaryNorm([-3,-2,-1.5,-1,-0.5,0.5,1,1.5,2,3], cmap.N, extend='both')\n",
        "BG = '#FFFFFF'; CARD = '#F0F0F0'; GRID = '#D0D0D0' # Changed BG to white, adjusted CARD and GRID for contrast\n",
        "M_ABBR = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']\n",
        "\n",
        "plt.rcParams.update({'font.family':'DejaVu Sans','figure.dpi':150,\n",
        "    'axes.titlesize':11,'axes.labelsize':9.5,\n",
        "    'xtick.labelsize':8.5,'ytick.labelsize':8.5})\n",
        "\n",
        "def style(ax):\n",
        "    ax.set_facecolor(CARD)\n",
        "    for sp in ax.spines.values(): sp.set_edgecolor(GRID)\n",
        "    ax.tick_params(colors='black') # Changed tick colors for white background\n",
