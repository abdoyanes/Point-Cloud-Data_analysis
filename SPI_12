      "source": [
        "# ============================================================\n",
        "# SPI-12 DROUGHT ANALYSIS FIGURE — Google Colab\n",
        "# Three Hydro-Climatic Phases (1952–2022)\n",
        "# Ed Dueim & Kosti Stations, White Nile State, Sudan\n",
        "# ============================================================\n",
        "# CELLS: paste each ## CELL block into a separate Colab cell\n",
        "# ============================================================\n",
        "\n",
        "## CELL 1 — Imports (no pip install needed)\n",
        "from google.colab import files\n",
        "import pandas as pd, numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.gridspec as gridspec\n",
        "import matplotlib.patches as mpatches\n",
        "import matplotlib.ticker as mticker\n",
        "from matplotlib.colors import LinearSegmentedColormap, BoundaryNorm\n",
        "from scipy.stats import gamma, norm\n",
        "from scipy.ndimage import uniform_filter1d\n",
        "import warnings; warnings.filterwarnings('ignore')\n",
        "print(\"✔ Imports ready\")\n",
        "\n",
        "## CELL 2 — Upload data\n",
        "print(\"Upload: Ed_Dueim_Station.csv  and  Kosti_Station.csv\")\n",
        "uploaded = files.upload()\n",
        "\n",
        "## CELL 3 — Compute SPI-12 (calendar-month gamma fit — McKee et al. 1993)\n",
        "def compute_spi(fname, scale=12):\n",
        "    df = pd.read_csv(fname)\n",
        "    df.columns = [c.lower() for c in df.columns]\n",
        "    df.rename(columns={'date':'year','rainfall':'rainfall_mm'}, inplace=True)\n",
        "    df = df.sort_values(['year','month']).reset_index(drop=True)\n",
        "    df['roll'] = df['rainfall_mm'].rolling(scale, min_periods=scale).sum()\n",
        "    spi_vals = np.full(len(df), np.nan)\n",
        "    for m in range(1, 13):\n",
        "        idx = df[df['month']==m].index\n",
        "        x   = df.loc[idx,'roll'].dropna().values\n",
        "        wet = x[x>0]; q0 = (len(x)-len(wet)) / len(x)\n",
        "        if len(wet) < 4: continue\n",
        "        try:\n",
        "            a, loc, sc = gamma.fit(wet, floc=0)\n",
        "            for i in idx:\n",
        "                v = df.loc[i,'roll']\n",
        "                if np.isnan(v): continue\n",
        "                cdf = q0 if v<=0 else q0 + (1-q0)*gamma.cdf(v, a, loc, sc)\n",
        "                spi_vals[i] = norm.ppf(np.clip(cdf, 1e-6, 1-1e-6))\n",
        "        except: pass\n",
        "    df['spi12'] = spi_vals\n",
        "    return df\n",
        "\n",
        "dd = compute_spi('Ed Dueim_Station.csv')\n",
        "dk = compute_spi('Kosti_Station.csv')\n",
        "\n",
        "def annual_spi(df):\n",
        "    return df.dropna(subset=['spi12']).groupby('year')['spi12'].mean()\n",
        "\n",
        "ann_d = annual_spi(dd)\n",
        "ann_k = annual_spi(dk)\n",
        "\n",
        "def spi_matrix(df):\n",
        "    d2 = df.dropna(subset=['spi12'])\n",
        "    yrs = sorted(d2['year'].unique())\n",
        "    mat = np.full((12, len(yrs)), np.nan)\n",
        "    for yi, yr in enumerate(yrs):\n",
        "        for m in range(1, 13):\n",
        "            v = d2[(d2['year']==yr)&(d2['month']==m)]['spi12'].values\n",
        "            if len(v): mat[m-1, yi] = v[0]\n",
        "    return mat, np.array(yrs)\n",
        "\n",
        "mat_d, yrs_d = spi_matrix(dd)\n",
        "mat_k, yrs_k = spi_matrix(dk)\n",
        "\n",
        "# Phase definitions\n",
        "PHASES = [\n",
        "    (1952, 1969, 'Ph.I\\n1952-69',   '#5B8DB8', 'Pre-drought'),\n",
        "    (1970, 1989, 'Ph.II\\n1970-89',  '#C0392B', 'Pan-Sahelian drought'),\n",
        "    (1990, 2004, 'Ph.III\\n1990-04', '#27AE60', 'Partial recovery'),\n",
        "    (2005, 2022, 'Ph.IV\\n2005-22',  '#E67E22', 'High-freq. oscillation'),\n",
        "]\n",
        "print(\"Phase mean SPI-12:\")\n",
        "for y1,y2,lbl,col,desc in PHASES:\n",
        "    md = ann_d[(ann_d.index>=y1)&(ann_d.index<=y2)].mean()\n",
        "    mk = ann_k[(ann_k.index>=y1)&(ann_k.index<=y2)].mean()\n",
        "    print(f\"  {desc:<28} Ed Dueim: {md:+.3f}  Kosti: {mk:+.3f}\")\n",
        "print(\"✔ SPI computed\")\n",
        "\n",
        "## CELL 4 — Build figure\n",
        "CMAP_C = ['#7B0000','#C0392B','#E74C3C','#F39C12',\n",
        "          '#F8F9FA','#85C1E9','#2E86C1','#1B4F72','#0B2D47']\n",
        "cmap  = LinearSegmentedColormap.from_list('spi', CMAP_C, N=512)\n",
        "bnorm = BoundaryNorm([-3,-2,-1.5,-1,-0.5,0.5,1,1.5,2,3], cmap.N, extend='both')\n",
        "BG = '#12181F'; CARD = '#1A2330'; GRID = '#243040'\n",
        "M_ABBR = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']\n",
        "\n",
        "plt.rcParams.update({'font.family':'DejaVu Sans','figure.dpi':150,\n",
        "    'axes.titlesize':11,'axes.labelsize':9.5,\n",
        "    'xtick.labelsize':8.5,'ytick.labelsize':8.5})\n",
        "\n",
        "def style(ax):\n",
        "    ax.set_facecolor(CARD)\n",
        "    for sp in ax.spines.values(): sp.set_edgecolor(GRID)\n",
        "    ax.tick_params(colors='white')\n",
        "    ax.xaxis.label.set_color('white')\n",
        "    ax.yaxis.label.set_color('white')\n",
        "    ax.title.set_color('white')\n",
        "\n",
        "fig, axes = plt.subplots(3, 2, figsize=(18, 16),\n",
        "    gridspec_kw=dict(height_ratios=[1.0,1.2,1.1], hspace=0.52, wspace=0.28))\n",
        "fig.patch.set_facecolor(BG)\n",
        "\n",
        "# ── Row 0: Heatmaps ───────────────────────────────────────────────────────\n",
        "for col, (mat, yrs, name, panel) in enumerate([\n",
        "        (mat_d, yrs_d, 'Ed Dueim','(a)'),\n",
        "        (mat_k, yrs_k, 'Kosti',   '(b)')]):\n",
        "    ax = axes[0, col]; style(ax)\n",
        "    ax.imshow(mat, aspect='auto', cmap=cmap, norm=bnorm,\n",
        "              interpolation='nearest',\n",
        "              extent=[yrs[0]-0.5, yrs[-1]+0.5, 11.5, -0.5])\n",
        "    for y1,y2,lbl,col2,_ in PHASES:\n",
        "        ax.axvline(y1-0.5, color=col2, lw=1.1, alpha=0.55, ls='--', zorder=3)\n",
        "        ax.text((y1+y2)/2, -0.6, lbl, ha='center', va='bottom', fontsize=7.5,\n",
        "                color=col2, fontweight='bold',\n",
        "                transform=ax.get_xaxis_transform(), clip_on=False)\n",
        "    ax.set_yticks(range(12)); ax.set_yticklabels(M_ABBR, fontsize=8)\n",
        "    ax.set_xticks(range(1955,2023,10))\n",
        "    ax.set_xticklabels([str(y) for y in range(1955,2023,10)])\n",
        "    ax.set_title(f'SPI-12 Monthly Heatmap -- {name}', pad=10)\n",
        "    ax.set_xlabel('Year')\n",
        "    ax.text(0.01,0.97,panel,transform=ax.transAxes,\n",
        "            fontsize=12,fontweight='bold',color='white',va='top')\n",
        "    # Mark driest month in Phase II\n",
        "    ph2i = np.where((yrs>=1970)&(yrs<=1989))[0]\n",
        "    if len(ph2i):\n",
        "        sub = mat[:,ph2i]; vi = np.argwhere(~np.isnan(sub))\n",
        "        if len(vi):\n",
        "            wi = vi[np.argmin(sub[vi[:,0],vi[:,1]])]\n",
        "            ax.add_patch(mpatches.Rectangle(\n",
        "                (yrs[ph2i[wi[1]]]-0.5,wi[0]-0.5),1,1,\n",
        "                fill=False,edgecolor='yellow',lw=1.8,zorder=5))\n",
        "\n",
        "# Colorbar\n",
        "cax = fig.add_axes([0.965,0.705,0.011,0.21])\n",
        "sm  = plt.cm.ScalarMappable(cmap=cmap,norm=bnorm); sm.set_array([])\n",
        "cb  = fig.colorbar(sm,cax=cax,extend='both')\n",
        "cb.set_label('SPI-12',color='white',fontsize=8,labelpad=5)\n",
        "cb.set_ticks([-2,-1.5,-1,-0.5,0,0.5,1,1.5,2])\n",
        "cb.ax.yaxis.set_tick_params(color='white')\n",
        "plt.setp(cb.ax.yaxis.get_ticklabels(),color='white',fontsize=7.5)\n",
        "\n",
        "# ── Row 1: Annual SPI bars ────────────────────────────────────────────────\n",
        "for col,(ann,name,panel) in enumerate([(ann_d,'Ed Dueim','(c)'),(ann_k,'Kosti','(d)')]):\n",
        "    ax = axes[1,col]; style(ax)\n",
        "    yrs_a = ann.index.values; vals = ann.values\n",
        "    for y1,y2,_,col2,__ in PHASES:\n",
        "        ax.axvspan(y1-0.5,y2+0.5,alpha=0.09,color=col2,zorder=0)\n",
        "        ax.axvline(y1-0.5,color=col2,lw=0.9,alpha=0.4,ls='--',zorder=1)\n",
        "    for th,c2,ls in [(-2.0,'#8B0000',':'),(- 1.5,'#C0392B','--'),\n",
        "                      (-1.0,'#E67E22','-.'),(1.0,'#2980B9','-.')]:\n",
        "        ax.axhline(th,color=c2,lw=0.7,ls=ls,alpha=0.55,zorder=1)\n",
        "    ax.bar(yrs_a,vals,width=0.75,\n",
        "           color=['#2980B9' if v>=0 else '#C0392B' for v in vals],\n",
        "           alpha=0.82,edgecolor='none',zorder=2)\n",
        "    sm5 = uniform_filter1d(vals,size=5,mode='nearest')\n",
        "    ax.plot(yrs_a,sm5,color='#F1C40F',lw=2.2,alpha=0.90,zorder=4,label='5-yr mean')\n",
        "    ax.axhline(0,color='white',lw=0.8,alpha=0.5,zorder=3)\n",
        "    roman = ['I','II','III','IV']\n",
        "    for ri,(y1,y2,_,col2,__) in enumerate(PHASES):\n",
        "        sub = ann[(ann.index>=y1)&(ann.index<=y2)]\n",
