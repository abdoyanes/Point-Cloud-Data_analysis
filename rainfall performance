      "source": [
        "correlation_results = []\n",
        "\n",
        "for location in [\"Ed Dueim\", \"Kosti\"]:\n",
        "    obs_data = all_data[(all_data[\"Location\"] == location) & (all_data[\"Product\"] == \"Observed\")]\n",
        "\n",
        "    for product in [\"CHIRPS\", \"ERA5\", \"IMERG\"]:\n",
        "        pred_data = all_data[(all_data[\"Location\"] == location) & (all_data[\"Product\"] == product)]\n",
        "\n",
        "        merged_corr_data = pd.merge(obs_data[[\"Date_full\", \"Rainfall\", \"Season\"]],\n",
        "                                    pred_data[[\"Date_full\", \"Rainfall\"]],\n",
        "                                    on=\"Date_full\",\n",
        "                                    suffixes=('_obs', '_pred'))\n",
        "\n",
        "        for period in [\"Full\", \"Pre-monsoon (May-Jun)\", \"Peak-monsoon (Aug)\"]:\n",
        "            if period == \"Full\":\n",
        "                data_for_corr = merged_corr_data\n",
        "            else:\n",
        "                data_for_corr = merged_corr_data[merged_corr_data[\"Season\"] == period]\n",
        "\n",
        "            if len(data_for_corr) > 1: # Correlation requires at least 2 data points\n",
        "                correlation = data_for_corr['Rainfall_obs'].corr(data_for_corr['Rainfall_pred'], method='pearson')\n",
        "            else:\n",
        "                correlation = np.nan # Not enough data for correlation\n",
        "\n",
        "            correlation_results.append({\n",
        "                \"Location\": location,\n",
        "                \"Product\": product,\n",
        "                \"Period\": period,\n",
        "                \"Pearson_Correlation\": correlation\n",
        "            })\n",
        "\n",
        "df_correlation = pd.DataFrame(correlation_results)\n",
        "\n",
        "print(\"\\n\" + \"=\"*70)\n",
        "print(\"Pearson Correlation between Observed and Satellite Rainfall by Season\")\n",
        "print(\"=\"*70)\n",
        "display(df_correlation.round(3))"
