        "\n",
        "    # Plot data points\n",
        "    for prod in [\"CHIRPS\", \"ERA5\", \"IMERG\"]:\n",
        "        prod_data = sub_data[sub_data[\"Product\"] == prod]\n",
        "        color = product_colors[prod]\n",
        "\n",
        "        for period_name, marker_style in period_markers_new.items():\n",
        "            period_data = prod_data[prod_data[\"Period\"] == period_name]\n",
