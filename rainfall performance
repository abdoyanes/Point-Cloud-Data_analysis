        "# ============================================================\n",
        "# CALCULATE METRICS FOR REQUESTED SEASONS\n",
        "# ============================================================\n",
        "new_results = []\n",
        "new_periods = [\"Full\", \"Winter (Nov-Feb)\", \"Pre-monsoon (Mar-May)\", \"Rainy (Jun-Oct)\"]\n",
        "\n",
        "for location in [\"Ed Dueim\", \"Kosti\"]:\n",
