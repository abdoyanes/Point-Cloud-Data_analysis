      },
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.metrics import confusion_matrix\n",
        "\n",
        "# Load the data for Ed Dueim (Observed)\n",
        "obs_ed_dueim = pd.read_csv('/content/Rainfall_Ed Dueim.csv')\n",
        "\n",
        "# Load the data for Kosti (Observed)\n",
        "obs_kosti = pd.read_csv('/content/Rainfall_Kosti.csv')\n",
        "\n",
        "# Load CHIRPS data for Ed Dueim\n",
        "chirps_ed = pd.read_csv('/content/chirps_Ed Dueim.csv')\n",
        "\n",
        "# Load CHIRPS data for Kosti\n",
        "chirps_kosti = pd.read_csv('/content/chirps_Kosti.csv')\n",
        "\n",
        "# Load ERA5 data for Ed Dueim\n",
        "era5_ed = pd.read_csv('/content/ERA_5_Ed Dueim.csv')\n",
        "\n",
        "# Load ERA5 data for Kosti\n",
        "era5_kosti = pd.read_csv('/content/ERA_5 _Kosti.csv')\n",
        "\n",
        "# Load IMERG data for Ed Dueim\n",
        "imerg_ed = pd.read_csv('/content/IMERG_Ed Dueim.csv')\n",
        "\n",
        "# Load IMERG data for Kosti\n",
        "imerg_kosti = pd.read_csv('/content/IMERG__Kosti.csv')\n",
        "\n",
        "# ============================================================\n",
        "# CLEAN AND STANDARDIZE COLUMNS\n",
        "# ============================================================\n",
        "for df in [obs_ed_dueim, obs_kosti, chirps_ed, chirps_kosti,\n",
        "           era5_ed, era5_kosti, imerg_ed, imerg_kosti]:\n",
        "    # Keep only first 3 columns if there are extra empty columns\n",
        "    if df.shape[1] > 3:\n",
        "        df = df.iloc[:, :3]\n",
        "    df.columns = [\"Date\", \"Month\", \"Rainfall\"]\n",
        "\n",
        "# Add labels\n",
        "obs_ed_dueim[\"Location\"] = \"Ed Dueim\"\n",
        "obs_kosti[\"Location\"] = \"Kosti\"\n",
        "obs_ed_dueim[\"Product\"] = \"Observed\"\n",
        "obs_kosti[\"Product\"] = \"Observed\"\n",
        "\n",
        "chirps_ed[\"Location\"] = \"Ed Dueim\"\n",
        "chirps_ed[\"Product\"] = \"CHIRPS\"\n",
        "chirps_kosti[\"Location\"] = \"Kosti\"\n",
        "chirps_kosti[\"Product\"] = \"CHIRPS\"\n",
        "\n",
        "era5_ed[\"Location\"] = \"Ed Dueim\"\n",
        "era5_ed[\"Product\"] = \"ERA5\"\n",
        "era5_kosti[\"Location\"] = \"Kosti\"\n",
        "era5_kosti[\"Product\"] = \"ERA5\"\n",
        "\n",
        "imerg_ed[\"Location\"] = \"Ed Dueim\"\n",
        "imerg_ed[\"Product\"] = \"IMERG\"\n",
        "imerg_kosti[\"Location\"] = \"Kosti\"\n",
        "imerg_kosti[\"Product\"] = \"IMERG\"\n",
        "\n",
        "# Combine all\n",
        "all_data = pd.concat([\n",
        "    obs_ed_dueim, obs_kosti,\n",
        "    chirps_ed, chirps_kosti,\n",
        "    era5_ed, era5_kosti,\n",
        "    imerg_ed, imerg_kosti\n",
        "], ignore_index=True)\n",
        "\n",
        "# Create date\n",
        "all_data[\"Year\"] = all_data[\"Date\"].astype(int)\n",
        "all_data[\"Date_full\"] = pd.to_datetime(all_data[\"Year\"].astype(str) + \"-\" +\n",
        "                                        all_data[\"Month\"].astype(str) + \"-01\")\n",
        "\n",
        "# Add season\n",
        "all_data[\"Season\"] = \"Other\"\n",
        "all_data.loc[all_data[\"Month\"].isin([5,6]), \"Season\"] = \"Pre-monsoon (May-Jun)\"\n",
        "all_data.loc[all_data[\"Month\"] == 8, \"Season\"] = \"Peak-monsoon (Aug)\"\n",
        "\n",
        "# Add requested season for new analysis\n",
        "all_data[\"Requested_Season\"] = \"Other\"\n",
        "all_data.loc[all_data[\"Month\"].isin([11, 12, 1, 2]), \"Requested_Season\"] = \"Winter (Nov-Feb)\"\n",
        "all_data.loc[all_data[\"Month\"].isin([3, 4, 5]), \"Requested_Season\"] = \"Pre-monsoon (Mar-May)\"\n",
        "all_data.loc[all_data[\"Month\"].isin([6, 7, 8, 9, 10]), \"Requested_Season\"] = \"Rainy (Jun-Oct)\"\n",
        "\n",
        "# ============================================================\n",
        "# DETECTION METRICS FUNCTION\n",
        "# ============================================================\n",
        "def detection_metrics(obs, pred, threshold=10):\n",
        "    obs_bin = (obs >= threshold).astype(int)\n",
        "    pred_bin = (pred >= threshold).astype(int)\n",
        "    tn, fp, fn, tp = confusion_matrix(obs_bin, pred_bin, labels=[0,1]).ravel()\n",
        "    POD = tp/(tp+fn) if (tp+fn)>0 else np.nan\n",
        "    FAR = fp/(tp+fp) if (tp+fp)>0 else np.nan\n",
        "    CSI = tp/(tp+fn+fp) if (tp+fn+fp)>0 else np.nan\n",
        "    BIAS = (tp+fp)/(tp+fn) if (tp+fn)>0 else np.nan # Calculate Bias\n",
        "    return {\"POD\": POD, \"FAR\": FAR, \"CSI\": CSI, \"BIAS\": BIAS, \"Hits\": tp, \"FalseAlarms\": fp}\n",
        "\n",
        "# ============================================================\n",
        "# CALCULATE METRICS\n",
        "# ============================================================\n",
        "results = []\n",
        "for location in [\"Ed Dueim\", \"Kosti\"]:\n",
        "    obs = all_data[(all_data[\"Location\"]==location) & (all_data[\"Product\"]==\"Observed\")]\n",
        "    for product in [\"CHIRPS\", \"ERA5\", \"IMERG\"]:\n",
        "        pred = all_data[(all_data[\"Location\"]==location) & (all_data[\"Product\"]==product)]\n",
        "        merged = pd.merge(obs[[\"Date\",\"Month\",\"Rainfall\",\"Season\"]],\n",
        "                         pred[[\"Date\",\"Month\",\"Rainfall\"]],\n",
        "                         on=[\"Date\",\"Month\"], suffixes=[\"_obs\",\"_pred\"])\n",
        "\n",
        "        for period in [\"Full\", \"Pre-monsoon (May-Jun)\", \"Peak-monsoon (Aug)\"]:\n",
        "            if period == \"Full\":\n",
        "                data = merged\n",
        "            else:\n",
        "                data = merged[merged[\"Season\"]==period]\n",
        "            if len(data) > 0:\n",
        "                stats = detection_metrics(data[\"Rainfall_obs\"], data[\"Rainfall_pred\"])\n",
        "                results.append({\"Location\":location, \"Product\":product, \"Period\":period, **stats})\n",
        "\n",
        "df_results = pd.DataFrame(results)\n",
        "\n",
        "# ============================================================\n",
        "# PRINT TABLE\n",
        "# ============================================================\n",
        "print(\"\\n\" + \"=\"*90)\n",
        "print(\"TABLE: Monthly Rainfall Detection Skill (threshold = 10 mm/month)\")\n",
        "print(\"=\"*90)\n",
        "print(df_results.round(3).to_string(index=False))\n",
        "\n",
        "# ============================================================\n",
        "# CREATE FIGURES\n",
        "# ============================================================\n",
        "# Figure 1: Bar plots\n",
        "fig, axes = plt.subplots(2, 3, figsize=(15, 10))\n",
        "for i, loc in enumerate([\"Ed Dueim\", \"Kosti\"]):\n",
        "    for j, metric in enumerate([\"POD\", \"FAR\", \"CSI\"]):\n",
        "        sub = df_results[df_results[\"Location\"]==loc]\n",
        "        pivot = sub.pivot(index=\"Product\", columns=\"Period\", values=metric)\n",
        "        pivot.plot(kind=\"bar\", ax=axes[i,j], rot=45, colormap=\"viridis\")\n",
        "        axes[i,j].set_title(f\"{loc} - {metric}\")\n",
        "        axes[i,j].set_ylim(0,1)\n",
        "        axes[i,j].axhline(0.5, linestyle=\"--\", color=\"gray\", alpha=0.5)\n",
        "        axes[i,j].legend(loc=\"upper right\") # Changed from \"best\" to \"upper right\"\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"monthly_detection_skill.png\", dpi=600)\n",
        "plt.show()\n",
        "\n",
        "# Figure 2: FAR vs POD (virga signature)\n",
        "fig, axes = plt.subplots(1, 2, figsize=(15, 6)) # Increased figure size for legends\n",
        "\n",
        "# Define color palette for products\n",
        "product_colors = {\n",
        "    \"CHIRPS\": \"#1f77b4\", # Matplotlib default blue\n",
        "    \"ERA5\": \"#ff7f0e\",   # Matplotlib default orange\n",
        "    \"IMERG\": \"#2ca02c\"   # Matplotlib default green\n",
        "}\n",
        "\n",
        "# Define marker styles for periods\n",
        "period_markers = {\n",
        "    \"Pre-monsoon (May-Jun)\": \"o\", # Circle\n",
        "    \"Peak-monsoon (Aug)\": \"^\"     # Triangle\n",
        "}\n",
        "\n",
        "for i, loc in enumerate([\"Ed Dueim\", \"Kosti\"]):\n",
        "    ax = axes[i]\n",
        "    sub = df_results[df_results[\"Location\"]==loc]\n",
        "\n",
        "    # Plot actual data\n",
        "    for prod in [\"CHIRPS\", \"ERA5\", \"IMERG\"]:\n",
        "        prod_data = sub[sub[\"Product\"]==prod]\n",
        "        color = product_colors[prod]\n",
        "\n",
        "        pre = prod_data[prod_data[\"Period\"]==\"Pre-monsoon (May-Jun)\"]\n",
        "        peak = prod_data[prod_data[\"Period\"]==\"Peak-monsoon (Aug)\"]\n",
        "\n",
        "        if len(pre)>0:\n",
        "            ax.scatter(pre.iloc[0][\"POD\"], pre.iloc[0][\"FAR\"],\n",
        "                       s=pre.iloc[0][\"FalseAlarms\"]*20, # Size proportional to FalseAlarms\n",
        "                       color=color, # Color by Product\n",
        "                       marker=period_markers[\"Pre-monsoon (May-Jun)\"], # Marker by Period\n",
        "                       alpha=0.7)\n",
        "\n",
        "        if len(peak)>0:\n",
        "            ax.scatter(peak.iloc[0][\"POD\"], peak.iloc[0][\"FAR\"],\n",
        "                       s=peak.iloc[0][\"FalseAlarms\"]*20, # Size proportional to FalseAlarms\n",
        "                       color=color, # Color by Product\n",
        "                       marker=period_markers[\"Peak-monsoon (Aug)\"], # Marker by Period\n",
        "                       alpha=0.7)\n",
        "\n",
        "    ax.set_xlabel(\"POD\"); ax.set_ylabel(\"FAR\")\n",
        "    ax.set_title(f\"{loc}: High FAR = possible virga\")\n",
        "    ax.set_xlim(0,1); ax.set_ylim(0,1)\n",
        "    ax.plot([0,1],[0,1], 'k--', alpha=0.3) # 1:1 line\n",
        "    ax.grid(True, alpha=0.3)\n",
        "\n",
        "    # --- Create Custom Legends ---\n",
        "    # These legends will be placed outside each subplot\n",
        "\n",
        "    # 1. Product Legend (colors)\n",
        "    product_legend_handles = []\n",
        "    for prod, color in product_colors.items():\n",
        "        product_legend_handles.append(plt.Line2D([0], [0], marker='o', color='w',\n",
        "                                                 label=prod, markerfacecolor=color,\n",
        "                                                 markersize=8))\n",
        "    product_legend = ax.legend(handles=product_legend_handles, loc=\"upper left\",\n",
        "                               bbox_to_anchor=(1.05, 1.0), title=\"Product\", frameon=False)\n",
        "    ax.add_artist(product_legend)\n",
        "\n",
        "    # 2. Period Legend (markers)\n",
        "    period_legend_handles = []\n",
        "    for period, marker in period_markers.items():\n",
        "        # Using period.split(' ')[0] for cleaner legend labels (e.g., 'Pre-monsoon')\n",
        "        period_legend_handles.append(plt.Line2D([0], [0], marker=marker, color='w',\n",
        "                                                label=period.split(' ')[0],\n",
        "                                                markerfacecolor='black', markeredgecolor='black',\n",
        "                                                markersize=8))\n",
        "    period_legend = ax.legend(handles=period_legend_handles, loc=\"upper left\",\n",
        "                              bbox_to_anchor=(1.05, 0.75), title=\"Period\", frameon=False)\n",
        "    ax.add_artist(period_legend)\n",
        "\n",
        "    # 3. False Alarms Size Legend\n",
        "    false_alarms_sizes_for_legend = [5, 20, 50] # Example FalseAlarm values to show range\n",
        "    size_legend_handles = []\n",
        "    for fa_val in false_alarms_sizes_for_legend:\n",
        "        # markersize is proportional to diameter, s (in scatter) is proportional to area.\n",
        "        # So, markersize should be proportional to sqrt(s).\n",
        "        # Using a fixed scale factor relative to the largest expected 's' value\n",
        "        markersize_scale_factor = 8 / np.sqrt(50 * 20) # Scale so FA=50 has markersize=8\n",
        "        size_legend_handles.append(plt.Line2D([0], [0], marker='o', color='w',\n",
        "                                                label=f'{fa_val}', markerfacecolor='gray',\n",
        "                                                markersize=np.sqrt(fa_val * 20) * markersize_scale_factor))\n",
        "    size_legend = ax.legend(handles=size_legend_handles, loc=\"upper left\",\n",
        "                            bbox_to_anchor=(1.05, 0.5), title=\"False Alarms Count\", frameon=False)\n",
        "    ax.add_artist(size_legend)\n",
        "\n",
        "\n",
        "plt.tight_layout(rect=[0, 0, 0.85, 1]) # Adjust layout to make space for the legends\n",
        "plt.savefig(\"FAR_vs_POD_virga.png\", dpi=600)\n",
        "plt.show()\n",
        "\n",
        "# ============================================================\n",
        "# PRINT SUMMARY\n",
        "# ============================================================\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"SUMMARY FOR WHITE NILE STATE\")\n",
        "print(\"=\"*80)\n",
        "for loc in [\"Ed Dueim\", \"Kosti\"]:\n",
        "    print(f\"\\n{loc}:\")\n",
        "    sub = df_results[df_results[\"Location\"]==loc]\n",
        "    for prod in [\"CHIRPS\", \"ERA5\", \"IMERG\"]:\n",
        "        pre = sub[(sub[\"Product\"]==prod) & (sub[\"Period\"]==\"Pre-monsoon (May-Jun)\")]\n",
        "        peak = sub[(sub[\"Product\"]==prod) & (sub[\"Period\"]==\"Peak-monsoon (Aug)\")]\n",
        "        if len(pre)>0 and len(peak)>0:\n",
        "            print(f\"\\n{prod}:\")\n",
        "            print(f\"  Pre-monsoon: POD={pre.iloc[0]['POD']:.2f}, FAR={pre.iloc[0]['FAR']:.2f}\")\n",
        "            print(f\"  Peak-monsoon: POD={peak.iloc[0]['POD']:.2f}, FAR={peak.iloc[0]['FAR']:.2f}\")\n",
        "            if pre.iloc[0]['FAR'] > peak.iloc[0]['FAR']:\n",
        "                print(f\"  → FAR decreases → Virga effect (dry pre-monsoon atmosphere)\")"
      ],
